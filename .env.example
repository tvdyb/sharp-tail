# Sharp-tail Polymarket mirror trader configuration
# Copy this file to .env and fill in your credentials.

# Required: Your Ethereum private key (hex) for signing CLOB orders.
# This is the key for your Polymarket wallet on Polygon.
# DO NOT commit your .env file to git.
POLYMARKET_PRIVATE_KEY=

# Optional: CLOB API credentials.
# If omitted, they will be derived from your private key on first run.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Optional: Database and logging
POLYMIR_DB_PATH=polymir.db
POLYMIR_LOG_LEVEL=INFO
